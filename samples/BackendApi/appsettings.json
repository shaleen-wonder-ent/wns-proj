{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  // In production set these as App Service "Application settings" (or Key Vault
  // references) instead of committing real values here.
  "NotificationHub": {
    "HubName": "<your hub name e.g. wns-demo-hub>",
    "FullConnectionString": "<DefaultFullSharedAccessSignature connection string>"
  },
  // Callers must send this value in the "X-Api-Key" header. Leave empty to disable
  // the check (NOT recommended for anything reachable from the internet).
  "Api": {
    "Key": ""
  }
}
